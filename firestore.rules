rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isEditorOrAdmin() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["admin", "editor"];
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /courses/{courseId} {
      allow read: if signedIn();
      allow create, update, delete: if isEditorOrAdmin();
    }

    match /courseCalendarEvents/{eventId} {
      allow read: if signedIn();
      allow create, update, delete: if isEditorOrAdmin();
    }

    match /internalNotes/{noteId} {
      allow read: if signedIn() &&
        (resource.data.fromUserId == request.auth.uid || resource.data.toUserId == request.auth.uid || isAdmin());
      allow create: if signedIn() &&
        request.resource.data.fromUserId == request.auth.uid;
      allow update, delete: if signedIn() &&
        (resource.data.fromUserId == request.auth.uid || isAdmin());
    }
  }
}
